generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ip {
  id           Int        @id @default(autoincrement())
  name         String
  englishName  String?
  originalName String?
  officialUrl  String?
  description  String?    @db.Text
  status       IpStatus   @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  goods        Goods[]
  ipEvents     IpEvent[]

  @@index([name])
  @@map("ips")
}

model Goods {
  id                Int       @id @default(autoincrement())
  ipId              Int
  name              String
  goodsType         String?
  saleType          SaleType  @default(SINGLE)
  officialPrice     Int?
  isNotForSale      Boolean   @default(false)
  releaseDate       DateTime?
  officialUrl       String?
  thumbnailImageUrl String?
  description       String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ip                Ip        @relation(fields: [ipId], references: [id])
  goodsItems        GoodsItem[]
  eventGoods        EventGoods[]

  @@index([ipId])
  @@index([name])
  @@map("goods")
}

model GoodsItem {
  id                Int       @id @default(autoincrement())
  goodsId           Int
  name              String
  characterName     String?
  imageUrl          String?
  rarity            String?
  dropRate          Float?
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  goods             Goods     @relation(fields: [goodsId], references: [id], onDelete: Cascade)

  @@index([goodsId])
  @@index([name])
  @@index([characterName])
  @@map("goods_items")
}

enum SaleType {
  SINGLE
  SELECTABLE
  RANDOM
}

model IpEvent {
  id          Int       @id @default(autoincrement())
  ipId        Int
  name        String
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  officialUrl String?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ip          Ip        @relation(fields: [ipId], references: [id])
  eventGoods  EventGoods[]

  @@index([ipId])
  @@index([name])
  @@map("ip_events")
}

model EventGoods {
  eventId   Int
  goodsId   Int
  createdAt DateTime @default(now())

  event     IpEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  goods     Goods    @relation(fields: [goodsId], references: [id], onDelete: Cascade)

  @@id([eventId, goodsId])
  @@index([goodsId])
  @@map("event_goods")
}

enum IpStatus {
  ACTIVE
  INACTIVE
}