generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ip {
  id           Int       @id @default(autoincrement())
  name         String
  englishName  String?
  originalName String?
  officialUrl  String?
  description  String?   @db.Text
  status       IpStatus  @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  goods        Goods[]
  ipEvents     IpEvent[]

  @@index([name])
  @@map("ips")
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String
  officialUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goods Goods[]
}

model Goods {
  id                Int          @id @default(autoincrement())
  ipId              Int
  name              String
  officialPrice     Int?
  releaseDate       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  description       String?      @db.Text
  goodsType         String?
  officialUrl       String?
  thumbnailImageUrl String?
  isNotForSale      Boolean      @default(false)
  saleType          SaleType     @default(SINGLE)
  version           Int?
  eventGoods        EventGoods[]
  ip                Ip           @relation(fields: [ipId], references: [id])
  goodsItems        GoodsItem[]
  companyId         Int?
  company           Company? @relation(fields: [companyId], references: [id])

  @@index([ipId])
  @@index([name])
  @@map("goods")
}

model GoodsItem {
  id            Int      @id @default(autoincrement())
  goodsId       Int
  name          String
  characterName String?
  imageUrl      String?
  rarity        String?
  dropRate      Float?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  goods         Goods    @relation(fields: [goodsId], references: [id], onDelete: Cascade)

  @@index([goodsId])
  @@index([name])
  @@index([characterName])
  @@map("goods_items")
}

model IpEvent {
  id          Int          @id @default(autoincrement())
  ipId        Int
  name        String
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  officialUrl String?
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  eventGoods  EventGoods[]
  ip          Ip           @relation(fields: [ipId], references: [id])

  @@index([ipId])
  @@index([name])
  @@map("ip_events")
}

model EventGoods {
  eventId   Int
  goodsId   Int
  createdAt DateTime @default(now())
  event     IpEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  goods     Goods    @relation(fields: [goodsId], references: [id], onDelete: Cascade)

  @@id([eventId, goodsId])
  @@index([goodsId])
  @@map("event_goods")
}

enum SaleType {
  SINGLE
  SELECTABLE
  RANDOM
}

enum IpStatus {
  ACTIVE
  INACTIVE
}
